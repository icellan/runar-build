---
import { getCollection, render } from 'astro:content';
import DocsLayout from '@layouts/DocsLayout.astro';
import { docsNavigation } from '@data/navigation';

export async function getStaticPaths() {
  const docs = await getCollection('docs', (entry) => !entry.data.draft);
  return docs.map((entry) => {
    // entry.id is like "en/getting-started/overview.mdx"
    // Strip the "en/" prefix and ".mdx" extension for URL
    const slug = entry.id.replace(/^en\//, '').replace(/\.mdx$/, '');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

// Find the section title from navigation data
const sectionKey = entry.data.section;
const section = docsNavigation.find(s => s.key === sectionKey);
const sectionTitle = section?.title || sectionKey;
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sectionTitle={sectionTitle}
  headings={headings}
>
  <Content />
</DocsLayout>
