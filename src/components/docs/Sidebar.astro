---
import SidebarSection from './SidebarSection.astro';
import { docsNavigation } from '@data/navigation';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<aside class="w-64 shrink-0 hidden lg:block">
  <nav class="sticky top-20 h-[calc(100vh-5rem)] overflow-y-auto pr-4 pb-8 scrollbar-thin" aria-label="Documentation sidebar">
    {docsNavigation.map(section => (
      <SidebarSection
        title={section.title}
        sectionKey={section.key}
        items={section.items}
        currentPath={currentPath}
      />
    ))}
  </nav>
</aside>
