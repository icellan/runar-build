---
interface Props {
  name: string;
  status: 'stable' | 'beta' | 'planned';
  snippet: string;
}

const { name, status, snippet } = Astro.props;

const statusColors = {
  stable: 'bg-success/10 text-success',
  beta: 'bg-warning/10 text-warning',
  planned: 'bg-neutral-500/10 text-text-tertiary',
};
---

<div class="group p-5 rounded-xl bg-surface border border-border hover:border-accent-500/30 transition-all duration-200">
  <div class="flex items-center justify-between mb-3">
    <h3 class="font-semibold text-sm">{name}</h3>
    <span class:list={['text-xs px-2 py-0.5 rounded-full font-mono', statusColors[status]]}>
      {status}
    </span>
  </div>
  <pre class="text-xs font-mono text-text-secondary leading-relaxed overflow-x-auto"><code>{snippet}</code></pre>
</div>
