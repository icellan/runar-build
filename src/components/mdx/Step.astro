---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="relative [counter-increment:step]">
  <div class="absolute -left-[33px] w-5 h-5 rounded-full bg-accent-500 text-neutral-950 flex items-center justify-center text-xs font-mono font-bold before:content-[counter(step)]"></div>
  <h4 class="font-semibold mb-2">{title}</h4>
  <div class="text-text-secondary text-sm">
    <slot />
  </div>
</div>
