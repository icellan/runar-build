---
interface Property {
  name: string;
  type: string;
  default?: string;
  description: string;
}

interface Props {
  properties: Property[];
}

const { properties } = Astro.props;
---

<div class="my-6 overflow-x-auto">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b-2 border-border-strong">
        <th class="text-left py-2 pr-4 font-semibold">Name</th>
        <th class="text-left py-2 pr-4 font-semibold">Type</th>
        <th class="text-left py-2 pr-4 font-semibold">Default</th>
        <th class="text-left py-2 font-semibold">Description</th>
      </tr>
    </thead>
    <tbody>
      {properties.map(prop => (
        <tr class="border-b border-border">
          <td class="py-2 pr-4 font-mono text-accent-500 text-xs">{prop.name}</td>
          <td class="py-2 pr-4 font-mono text-text-secondary text-xs">{prop.type}</td>
          <td class="py-2 pr-4 font-mono text-text-tertiary text-xs">{prop.default || '—'}</td>
          <td class="py-2 text-text-secondary">{prop.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
